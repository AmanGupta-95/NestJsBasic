# MongoDB Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_password_here
MONGO_APP_DB=nestjs_books

# Database URL for Prisma
# For local development (without Docker):
# DATABASE_URL="mongodb://admin:your_password_here@localhost:27017/nestjs_books?authSource=admin"
# For Docker Compose (use service name):
DATABASE_URL="mongodb://admin:your_password_here@mongodb:27017/nestjs_books?authSource=admin"

# Redis Configuration
# For local development: localhost
# For Docker Compose: redis (service name)
REDIS_HOST=redis
REDIS_PORT=6379

# Application
PORT=3000
NODE_ENV=production

# Docker Build Configuration
BUILD_TARGET=production
VOLUME_MODE=ro

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
